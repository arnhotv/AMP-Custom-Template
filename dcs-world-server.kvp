Meta.DisplayName=DCS World Dedicated Server
Meta.Description=DCS World Dedicated Server (private AMP draft; Windows direct, Linux via Wine)
Meta.OS=Windows, Linux
Meta.AarchSupport=NotSupported
Meta.Arch=x86_64
Meta.Author=OpenAI
Meta.URL=https://www.digitalcombatsimulator.com/en/downloads/world/server/
Meta.DisplayImageSource=
Meta.EndpointURIFormat={ip}:{GenericModule.App.Ports.$GamePort}
Meta.ConfigManifest=dcs-world-serverconfig.json
Meta.MetaConfigManifest=dcs-world-servermetaconfig.json
Meta.ConfigRoot=dcs-world-server.kvp
Meta.MinAMPVersion=2.6.0.8
Meta.SpecificDockerImage=cubecoders/ampbase:wine-stable
Meta.DockerRequired=False
Meta.DockerBaseReadOnly=False
Meta.ContainerPolicy=SupportedOnWindows, RecommendedOnLinux
Meta.ContainerPolicyReason=Linux requires Wine and Xvfb. Using the AMP wine-stable base image avoids installing those dependencies directly on the host.
Meta.ExtraSetupStepsURI=
Meta.Prerequisites=[]
Meta.ExtraContainerPackages=[]
Meta.ConfigReleaseState=NotSpecified
Meta.NoCommercialUsage=False
Meta.ConfigVersion=0.2
Meta.ReleaseNotes=Private AMP draft for DCS Dedicated Server. Supports Windows natively and Linux through Wine. Generates helper config files for DCS but the first install remains manual.
Meta.BreakingReleaseNotes=
Meta.AppConfigId=1b1fd6c7-8972-4c88-a4aa-0b8fcbeafab9
Meta.ImportableExtensions=[]
Meta.AppIsMultiIPAware=True

App.DisplayName=DCS World Dedicated Server
App.RootDir=./dcs-world-server/
App.BaseDirectory=./dcs-world-server/
App.SteamWorkshopDownloadLocation=
App.ExecutableWin=bin\DCS_server.exe
App.ExecutableLinux=/usr/bin/xvfb-run
App.WorkingDir=
App.LinuxCommandLineArgs=-a wine "./bin/DCS_server.exe"
App.WindowsCommandLineArgs=
App.CommandLineArgs={{$PlatformArgs}} -w {{WriteDirName}} {{CustomStartupArgs}}
App.UseLinuxIOREDIR=False
App.AppSettings={}
App.EnvironmentVariables={"WINEPREFIX":"{{$FullRootDir}}.wine","WINEARCH":"win64","WINEDEBUG":"-all","XDG_RUNTIME_DIR":"/tmp"}
App.CommandLineParameterFormat=--{0} {1}
App.CommandLineParameterDelimiter= 
App.ExitMethod=OS_CLOSE
App.ExitTimeout=60
App.ExitString=quit
App.ExitFile=app_exit.lck
App.HasWriteableConsole=False
App.HasReadableConsole=False
App.UDPLogger=False
App.SupportsLiveSettingsChanges=False
App.LiveSettingChangeCommandFormat=set {0} "{1}"
App.ForceIPBinding=False
App.SupportsIPv6=False
App.ApplicationIPBinding=0.0.0.0
App.Ports=@IncludeJson[dcs-world-serverports.json]
App.AdminPortRef=0
App.PrimaryApplicationPortRef=GamePort
App.UniversalSleepApplicationUDPPortRef=GamePortUDP
App.UniversalSleepSteamQueryPortRef=0
App.MaxUsers=16
App.UseRandomAdminPassword=False
App.PersistRandomPassword=False
App.RemoteAdminPassword=
App.AdminMethod=STDIO
App.IgnoreSTDOUTAfterRCON=False
App.AdminLoginTransform=None
App.LoginTransformPrefix=
App.RCONConnectDelaySeconds=30
App.RCONConnectRetrySeconds=15
App.RCONHeartbeatMinutes=0
App.RCONHeartbeatCommand=ping
App.RCONSelectIPMethod=Default
App.TelnetLoginFormat={0}
App.TelnetNewLineType=Default
App.UpdateSources=@IncludeJson[dcs-world-serverupdates.manual.json]
App.PreStartStages=[]
App.UserActions=[]
App.ForceUpdate=False
App.ForceUpdateReason=
App.Compatibility=None
App.RapidStartup=False
App.SmartExcludeExemptions=["*.cfg","*.conf","*.config","*.ini","*.json","*.xml","*.properties","*.kvp","*.yml","*.yaml","*.toml","*.lua","*.miz"]
App.SmartExcludeSupported=True
App.DumpFullChildProcessTree=False
App.MonitorChildProcess=False
App.MonitorChildProcessName=^.*DCS_server\.exe.*$
App.MonitorDirectChildOnly=False
App.SupportsUniversalSleep=False
App.WakeupMode=Any
App.ApplicationReadyMode=Immediate

Console.FilterMatchRegex=
Console.FilterMatchReplacement=
Console.ThrowawayMessageRegex=
Console.AppReadyRegex=^
Console.UserJoinRegex=^
Console.UserLeaveRegex=^
Console.UserChatRegex=^
Console.UpdateAvailableRegex=
Console.PreConnectRegex=
Console.ConnectIPRegex=
Console.MetricsRegex=
Console.HideFromConsoleRegex=
Console.SuppressLogAtStart=False
Console.UserActions={}

Limits.SleepMode=False
Limits.SleepOnStart=False
Limits.SleepDelayMinutes=5
Limits.DozeDelay=2
Limits.AutoRetryCount=2
Limits.SleepStartThresholdSeconds=25
